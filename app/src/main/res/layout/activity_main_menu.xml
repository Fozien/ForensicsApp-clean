<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F1923"
    tools:context=".MainMenuActivity">

    <!-- Верхний блок с эмблемой и заголовком -->
    <LinearLayout
        android:id="@+id/headerBlock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="56dp"
        android:paddingBottom="28dp"
        android:background="#0D2137"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Эмблема -->
        <ImageView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@mipmap/ic_launcher_round"
            android:layout_marginBottom="16dp"
            android:contentDescription="Логотип приложения"/>

        <!-- Название -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FIXATOR"
            android:textSize="26sp"
            android:textColor="#4A9FD4"
            android:textStyle="bold"
            android:letterSpacing="0.2"
            android:layout_marginBottom="6dp"/>

        <!-- Подзаголовок -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Система криминалистической фотофиксации"
            android:textSize="11sp"
            android:textColor="#5A8AAA"
            android:gravity="center"
            android:paddingHorizontal="24dp"/>

    </LinearLayout>

    <!-- Разделитель -->
    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1E3A5F"
        app:layout_constraintTop_toBottomOf="@id/headerBlock"/>

    <!-- Блок кнопок по центру -->
    <LinearLayout
        android:id="@+id/buttonsBlock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/divider"
        app:layout_constraintBottom_toTopOf="@id/footerBlock"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Карточка: Криминалистическая съёмка -->
        <androidx.cardview.widget.CardView
            android:id="@+id/btn_camera"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:foreground="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="#0D2137"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:strokeColor="#1E4976"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="18dp"
                android:gravity="center_vertical">

                <!-- Иконка -->
                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@android:drawable/ic_menu_camera"
                    android:padding="10dp"
                    android:backgroundTint="#1A3A5C"
                    app:tint="#4A9FD4"
                    android:contentDescription="Камера"/>

                <!-- Текст -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingHorizontal="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Криминалистическая съёмка"
                        android:textSize="15sp"
                        android:textColor="#C8DFF0"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Фотофиксация с контролем параметров положения"
                        android:textSize="12sp"
                        android:textColor="#5A8AAA"
                        android:layout_marginTop="3dp"/>

                </LinearLayout>

                <!-- Стрелка -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textSize="24sp"
                    android:textColor="#2A6496"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Карточка: Формализация описаний -->
        <androidx.cardview.widget.CardView
            android:id="@+id/btn_gpt_assistant"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:foreground="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="#0D2137"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:strokeColor="#1E4976"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="18dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@android:drawable/ic_menu_edit"
                    android:padding="10dp"
                    android:backgroundTint="#1A3A5C"
                    app:tint="#4A9FD4"
                    android:contentDescription="Формализация"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingHorizontal="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Формализация описаний"
                        android:textSize="15sp"
                        android:textColor="#C8DFF0"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Обработка текста через YandexGPT и отчёт PDF"
                        android:textSize="12sp"
                        android:textColor="#5A8AAA"
                        android:layout_marginTop="3dp"/>

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textSize="24sp"
                    android:textColor="#2A6496"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <!-- Футер -->
    <LinearLayout
        android:id="@+id/footerBlock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingVertical="16dp"
        android:background="#0A1520"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Учебный модуль криминалистики · v1.0"
            android:textSize="10sp"
            android:textColor="#2A5070"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>